{
  "name": "vscode-function-starlark",
  "displayName": "Function Starlark",
  "description": "Starlark IDE support for function-starlark compositions — autocomplete, hover docs, syntax highlighting",
  "version": "0.2.0",
  "publisher": "wompipomp",
  "license": "Apache-2.0",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/wompipomp/function-starlark-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "functionStarlark.restartServer",
        "title": "Restart Starlark LSP",
        "category": "Function Starlark"
      },
      {
        "command": "functionStarlark.clearSchemaCache",
        "title": "Clear Schema Cache",
        "category": "Function Starlark"
      },
      {
        "command": "functionStarlark.showOutput",
        "title": "Show Output",
        "category": "Function Starlark"
      }
    ],
    "languages": [
      {
        "id": "starlark",
        "aliases": [
          "Starlark",
          "starlark"
        ],
        "extensions": [
          ".star"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "starlark",
        "scopeName": "source.starlark",
        "path": "./syntaxes/starlark.tmGrammar.json"
      }
    ],
    "configuration": {
      "title": "Function Starlark",
      "properties": {
        "functionStarlark.lsp.path": {
          "type": "string",
          "default": "starlark-lsp",
          "description": "Path to the starlark-lsp binary"
        },
        "functionStarlark.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Starlark language server for autocomplete and hover docs"
        },
        "functionStarlark.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VSCode and the Starlark language server"
        },
        "functionStarlark.buildifier.path": {
          "type": "string",
          "default": "buildifier",
          "description": "Path to the buildifier binary"
        },
        "functionStarlark.buildifier.fixLintOnFormat": {
          "type": "boolean",
          "default": false,
          "description": "Apply buildifier lint fixes when formatting"
        },
        "functionStarlark.schemas.path": {
          "type": "string",
          "default": "",
          "description": "Path to a local directory containing schema .py files. When empty, uses the extension's global storage directory."
        },
        "functionStarlark.schemas.registry": {
          "type": "string",
          "default": "ghcr.io/wompipomp",
          "description": "Default OCI registry for schema artifacts (e.g., ghcr.io/wompipomp)"
        },
        "functionStarlark.schemas.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable schema IntelliSense with OCI auto-download and per-file load() scoping"
        }
      }
    },
    "configurationDefaults": {
      "[starlark]": {
        "editor.defaultFormatter": "wompipomp.vscode-function-starlark",
        "editor.formatOnSave": true
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "nanotar": "^0.3.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.25.12",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
